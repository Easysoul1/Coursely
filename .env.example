# ──────────────────────────────────────────
# Coursely — Production Environment Variables
# ──────────────────────────────────────────
# Copy this file to .env and fill in values.

# ── Database ──────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/coursely"

# ── Backend API ──────────────────────────
JWT_SECRET="change-this-to-a-random-secret"
JWT_EXPIRES_IN="7d"
API_PORT=4000
FRONTEND_URL="http://localhost:3000,https://your-production-domain.com"

# ── Clerk (Authentication) ───────────────
CLERK_SECRET_KEY="sk_test_ovL44qyjYudkc0edDq4wtnAN3WuRw6KCtiJa0PC7l5"
CLERK_WEBHOOK_SECRET="whsec_..."
CLERK_PUBLISHABLE_KEY="pk_test_ZHJpdmluZy1wYW5nb2xpbi00NC5jbGVyay5hY2NvdW50cy5kZXYk"

# ── Frontend (Next.js) ───────────────────
NEXT_PUBLIC_API_URL="http://localhost:4000"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_..."
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/dashboard"
