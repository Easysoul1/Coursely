# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/coursely"

# JWT (used for backend API authentication)
JWT_SECRET="your-jwt-secret-change-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=4000
NODE_ENV="development"

# CORS — comma-separated list of allowed origins
FRONTEND_URL="http://localhost:3000"

# Clerk (optional — only needed for token exchange with frontend)
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""
